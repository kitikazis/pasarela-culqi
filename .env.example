APP_NAME="Pasarela Culqi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Correos con permisos de admin (acciones sensibles como devoluciones), separados por comas.
ADMIN_EMAILS=

# Login del panel /admin. OBLIGATORIO definirlos: si quedan vacíos, el panel
# queda BLOQUEADO (ya no existe el default admin/123 en el código).
# ⚠️ Usa un usuario propio y una contraseña FUERTE (larga y aleatoria).
ADMIN_PANEL_USER=
ADMIN_PANEL_PASSWORD=

# Orígenes permitidos para CORS (separados por comas). En PRODUCCIÓN deja solo tu dominio:
#   CORS_ALLOWED_ORIGINS="https://anuncialo.pe,https://www.anuncialo.pe"
CORS_ALLOWED_ORIGINS="http://127.0.0.1:8000,http://localhost:8000"

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=culqi_test
DB_USERNAME=root
DB_PASSWORD=

# ── Culqi ────────────────────────────────────────────────────
# public_key → frontend (Checkout v4) | secret_key → solo backend
CULQI_PUBLIC_KEY=pk_test_XXXXXXXXXXXX
CULQI_SECRET_KEY=sk_test_XXXXXXXXXXXX
CULQI_BASE_URL=https://api.culqi.com/v2

# ── Culqi RSA ────────────────────────────────────────────────
# DESACTIVADO para sandbox. La encriptación se activa SOLA cuando ambas
# variables tienen valores REALES (de CulqiPanel → Desarrollo → RSA Keys).
# IMPORTANTE: la llave pública debe ir en UNA sola línea y entre comillas.
CULQI_RSA_ID=
CULQI_RSA_PUBLIC_KEY=
# Ejemplo de formato correcto para producción (una línea, con comillas):
# CULQI_RSA_ID=rs_live_xxxxxxxxxxxx
# CULQI_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIGf...AQAB\n-----END PUBLIC KEY-----"

# ── Login social (OAuth) ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
MICROSOFT_TENANT=common

# ── Moderación con IA (Google Perspective) — opcional ────────
PERSPECTIVE_ENABLED=false
PERSPECTIVE_API_KEY=
PERSPECTIVE_THRESHOLD=0.85

# ── Caché / Sesión ────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SAME_SITE=lax
# En PRODUCCIÓN (HTTPS) pon esto en true para que la cookie de sesión
# nunca viaje por HTTP. En local (http) déjalo en false.
SESSION_SECURE_COOKIE=false
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Correo ────────────────────────────────────────────────────
# Correo. Con "log" no se envía (solo se escribe en storage/logs). Para recibir
# el aviso de pago en tu correo (ADMIN_EMAILS), pon SMTP real (ej. cPanel):
#   MAIL_MAILER=smtp
#   MAIL_HOST=mail.anuncialo.pe   MAIL_PORT=465   MAIL_ENCRYPTION=ssl
#   MAIL_USERNAME=noreply@anuncialo.pe   MAIL_PASSWORD=tu_contraseña
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@anuncialo.pe"
MAIL_FROM_NAME="${APP_NAME}"
