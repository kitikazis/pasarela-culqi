APP_NAME="Pasarela Culqi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=culqi_test
DB_USERNAME=root
DB_PASSWORD=

# ── Culqi ────────────────────────────────────────────────────
# public_key → frontend (Checkout v4) | secret_key → solo backend
CULQI_PUBLIC_KEY=pk_test_XXXXXXXXXXXX
CULQI_SECRET_KEY=sk_test_XXXXXXXXXXXX
CULQI_BASE_URL=https://api.culqi.com/v2

# ── Culqi RSA ────────────────────────────────────────────────
# DESACTIVADO para sandbox. La encriptación se activa SOLA cuando ambas
# variables tienen valores REALES (de CulqiPanel → Desarrollo → RSA Keys).
# IMPORTANTE: la llave pública debe ir en UNA sola línea y entre comillas.
CULQI_RSA_ID=
CULQI_RSA_PUBLIC_KEY=
# Ejemplo de formato correcto para producción (una línea, con comillas):
# CULQI_RSA_ID=rs_live_xxxxxxxxxxxx
# CULQI_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIGf...AQAB\n-----END PUBLIC KEY-----"

# ── Login social (OAuth) ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI="${APP_URL}/auth/microsoft/callback"
MICROSOFT_TENANT=common

# ── Moderación con IA (Google Perspective) — opcional ────────
PERSPECTIVE_ENABLED=false
PERSPECTIVE_API_KEY=
PERSPECTIVE_THRESHOLD=0.85

# ── Caché / Sesión ────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Correo ────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@anuncios.pe"
MAIL_FROM_NAME="${APP_NAME}"
