# La home (/) la maneja Laravel (index.php), NO el index.html estático.
# Esto permite inyectar el cache-busting automático en los assets.
<IfModule mod_dir.c>
    DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ── Forzar HTTPS en producción ──────────────────────────────
    # (En cPanel, una vez instalado el certificado SSL.)
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ── Cabeceras de seguridad ──────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin"
    # HSTS: fuerza HTTPS por 1 año (activar solo con SSL ya funcionando)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Autocache de estáticos: CSS/JS siempre revalidados ──────────
# El navegador puede guardar el archivo, pero ANTES de usarlo pregunta al
# servidor si cambió (ETag / Last-Modified). Si no cambió => 304 (rápido);
# si cambió => baja la versión nueva. Así el responsive y cualquier cambio
# de estilo se ven al instante en cada deploy, sin limpiar caché a mano.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# ── Desactiva la caché de página de LiteSpeed (cPanel) ──────────
# "El otro caché": muchos hostings con cPanel usan LiteSpeed, que guarda
# una copia de la página y la sirve a todos. Esto la desactiva para que cada
# usuario reciba siempre la última versión. (Si el server no usa LiteSpeed,
# este bloque simplemente se ignora.)
<IfModule LiteSpeed>
    CacheDisable public /
    RewriteEngine On
    RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

# ── Compresión gzip (reduce ~70% el peso de texto: HTML/CSS/JS/JSON) ─────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css \
        application/javascript application/json image/svg+xml
</IfModule>

# ── Caché larga para imágenes y fuentes (rara vez cambian) ──────────────
#    NO se aplica a CSS/JS: esos usan el autocache de arriba (revalidación).
#    Si cambias una imagen y quieres forzar refresco, renómbrala.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg     "access plus 30 days"
    ExpiresByType image/png      "access plus 30 days"
    ExpiresByType image/gif      "access plus 30 days"
    ExpiresByType image/webp     "access plus 30 days"
    ExpiresByType image/svg+xml  "access plus 30 days"
    ExpiresByType image/x-icon   "access plus 30 days"
    ExpiresByType font/woff2     "access plus 1 year"
    ExpiresByType font/woff      "access plus 1 year"
</IfModule>

# ── Proteger archivos sensibles ─────────────────────────────────
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>
